# Supabase (Postgres)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key (replaces "service_role"). Bypasses RLS — never
# expose to the browser. Used by API routes for admin/server work.
SUPABASE_SECRET_KEY=

# Optional: comma-separated emails. Anyone signing up with an email in this
# list is auto-promoted to admin via the handle_new_user trigger if you also
# inserted them into public.admin_emails (see supabase/README.md).
ADMIN_EMAILS=